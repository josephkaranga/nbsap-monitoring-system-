{
  "name": "nbsap-monitoring-system",
  "version": "2.0.0",
  "private": true,
  "description": "NBSAP Monitoring System · Rwanda · National Biodiversity Strategy & Action Plan 2025–2030",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "supabase:types": "supabase gen types typescript --local > src/types/database.generated.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrate": "supabase db push",
    "supabase:reset": "supabase db reset"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.1",
    "chart.js": "^4.4.1",
    "jspdf": "^2.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "supabase": "^1.168.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
