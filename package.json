{
  "name": "nbsap-monitoring-system",
  "version": "2.0.0",
  "private": true,
  "description": "NBSAP Monitoring System · Rwanda · National Biodiversity Strategy & Action Plan 2025–2030",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "supabase:types": "supabase gen types typescript --local > src/types/database.generated.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrate": "supabase db push",
    "supabase:reset": "supabase db reset"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.55.0",
    "chart.js": "^4.6.1",
    "jspdf": "^2.5.1",
    "react": "^18.4.2",
    "react-dom": "^18.4.2"
  },
  "devDependencies": {
    "@types/react": "^18.4.2",
    "@types/react-dom": "^18.4.2",
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.0.0",
    "supabase": "^1.200.0",
    "typescript": "^5.8.0",
    "vite": "^5.6.2"
  },
  "overrides": {
    "rimraf": "^4.0.0",
    "glob": "^8.2.0",
    "tar": "^8.0.0"
  }
}
